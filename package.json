{
  "name": "@memizy/oqse",
  "version": "0.1.2",
  "description": "TypeScript SDK and Zod validators for the OQSE specification.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "SPECIFICATION.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "build": "npm run generate:schemas && tsc && vite build && tsx scripts/fix-types-entry.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
