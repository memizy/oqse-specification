{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)*$"
    },
    "appName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "pluginVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "minOqseVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "maxOqseVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "latexPackages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "itemProperties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metaProperties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "actions": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "types": {
          "anyOf": [
            {
              "type": "array",
              "items": [
                {
                  "type": "string",
                  "const": "*"
                }
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "assets": {
          "type": "object",
          "properties": {
            "image": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "audio": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "video": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "model": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "actions"
      ],
      "additionalProperties": false
    },
    "author": {
      "type": "string",
      "maxLength": 100
    },
    "authorUrl": {
      "type": "string",
      "format": "uri"
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "emoji": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "studyMode": {
      "type": "string",
      "enum": [
        "game",
        "fun",
        "drill"
      ]
    },
    "questionDensity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "appSpecific": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "id",
    "appName",
    "version",
    "capabilities"
  ],
  "additionalProperties": false
}