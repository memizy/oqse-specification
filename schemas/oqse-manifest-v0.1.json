{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "id": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
      ]
    },
    "appName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "pluginVersion": {
      "type": "string"
    },
    "minOqseVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "maxOqseVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "latexPackages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "itemProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metaProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "types": {
          "anyOf": [
            {
              "type": "array",
              "items": [
                {
                  "type": "string",
                  "const": "*"
                }
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "assets": {
          "type": "object",
          "properties": {
            "image": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "audio": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "video": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "model": {
              "anyOf": [
                {
                  "type": "array",
                  "items": [
                    {
                      "type": "string",
                      "const": "*"
                    }
                  ]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "actions"
      ],
      "additionalProperties": false
    },
    "author": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email",
          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "contributors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    },
    "license": {
      "type": "string",
      "maxLength": 100
    },
    "licenseUrl": {
      "type": "string",
      "format": "uri"
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z]{2,8}(-[a-zA-Z0-9\\-]+)*$"
      }
    },
    "description": {
      "type": "string",
      "maxLength": 5000
    },
    "emoji": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "studyMode": {
      "type": "string",
      "enum": [
        "game",
        "fun",
        "drill"
      ]
    },
    "questionDensity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "appSpecific": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "id",
    "appName",
    "version",
    "capabilities"
  ],
  "additionalProperties": false
}